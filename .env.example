VITE_SUPABASE_URL=https://SEU_REF.supabase.co
# Preferir anon (JWT eyJ...) no front — evita 401 Invalid API key no REST
VITE_SUPABASE_ANON_KEY=
# Opcional: sb_publishable_... (só anon costuma bastar)
# VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_STORAGE_BUCKET=article-media

# Service role: não commite (GitHub Push Protection). Vercel → SUPABASE_SERVICE_ROLE_KEY ou .env.local
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
